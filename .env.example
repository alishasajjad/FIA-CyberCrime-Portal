# ─────────────────────────────────────────────────────────────────────────────
# Cyber Crime Reporting Portal — FRONTEND environment variables
#
# Create React App inlines REACT_APP_* at BUILD time, so these must be set in the
# Vercel FRONTEND project (Settings → Environment Variables) BEFORE building.
# For local dev, copy this file to .env at the repo root.
# ─────────────────────────────────────────────────────────────────────────────

# Full API base of the deployed backend, INCLUDING the trailing /api segment.
# Local dev default (when unset) is http://localhost:5000/api
REACT_APP_API_URL=https://your-backend.vercel.app/api

# WebSockets do not work on Vercel serverless. Set to "false" in the Vercel
# frontend project to disable connection attempts; notification/reminder stores
# fall back to polling automatically. Leave unset locally to keep realtime on.
REACT_APP_ENABLE_REALTIME=false
