{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/cron/escalation", "schedule": "0 0 * * *" },
    { "path": "/api/cron/reminders", "schedule": "0 0 * * *" }
  ]
}
