# ─────────────────────────────────────────────────────────────────────────────
# Cyber Crime Reporting Portal — BACKEND environment variables
# Copy to .env for local dev. On Vercel, add these in:
#   Project (backend) → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# --- Core (REQUIRED) ---------------------------------------------------------
# PORT is used for local dev only; Vercel sets the port automatically.
PORT=5000
MONGO_URI=mongodb+srv://<atlas-username>:<atlas-password>@<cluster-name>.mongodb.net/CyberCrimeDB?retryWrites=true&w=majority&appName=<app-name>
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# --- Default admin seed (REQUIRED for first login) ---------------------------
DEFAULT_ADMIN_EMAIL=admin@cybercrime.local
DEFAULT_ADMIN_PASSWORD=Admin@12345

# --- Production / deployment (set these on Vercel) ---------------------------
NODE_ENV=production
# Exact frontend origin (NO trailing slash). Used for CORS.
CORS_ORIGIN=https://your-frontend.vercel.app
# Public origin of THIS backend (NO trailing slash). Used to build /uploads URLs
# for the local-disk storage fallback. Not needed when Cloudinary is used.
PUBLIC_BASE_URL=https://your-backend.vercel.app
TRUST_PROXY=true
# For cross-site cookies between the two Vercel domains:
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=none

# --- Cloudinary (REQUIRED on Vercel — serverless disk is read-only) ----------
# Easiest: paste the single CLOUDINARY_URL from your Cloudinary dashboard.
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# ...or set the three discrete values instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=cybercrime-evidence

# --- Background sweeps (Vercel Cron / external scheduler) ---------------------
# Shared secret protecting /api/cron/escalation and /api/cron/reminders.
# Vercel Cron sends it automatically as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=replace-with-a-long-random-string

# --- Optional tuning (sane defaults exist for all of these) -------------------
# ESCALATION_INTERVAL_MIN=15
# REMINDER_INTERVAL_MIN=5
# JSON_BODY_LIMIT=2mb
# REQUEST_TIMEOUT_MS=30000
# MAX_FILE_SIZE_MB=100
# MAX_TOTAL_UPLOAD_MB=1024
# MAX_FILES_PER_REQUEST=10
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300
# RATE_LIMIT_AUTH_MAX=20
# SESSION_COOKIE_NAME=ccrs_session
