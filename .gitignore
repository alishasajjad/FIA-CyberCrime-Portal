# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules
/.pnp
.pnp.js
.yarn/cache
.yarn/unplugged

# ─── Environment variables (NEVER commit real secrets) ──────────────────────
# .env.example files ARE committed (they hold placeholders only).
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# ─── Build / output ─────────────────────────────────────────────────────────
/build
build
dist
/coverage

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Uploaded evidence (runtime data — not source) ──────────────────────────
# Production uses Cloudinary; local disk uploads should not be committed.
backend/uploads/*
!backend/uploads/.keep

# ─── Vercel CLI (local project link) ────────────────────────────────────────
.vercel

# ─── Editor / IDE ───────────────────────────────────────────────────────────
.idea
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# ─── OS cruft ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Claude Code local settings (machine-specific) ──────────────────────────
.claude/settings.local.json

# ─── Misc ───────────────────────────────────────────────────────────────────
*.tgz
.cache
.eslintcache
